        const intervalId = setInterval(() => {
          const useRealData = db.length > 0 && Math.random() > 0.4;
          
          let selectedName, selectedProdi;
          if (useRealData) {
             const randomDbIndex = Math.floor(Math.random() * db.length);
             selectedName = db[randomDbIndex].nama;
             selectedProdi = db[randomDbIndex].programStudi;
          } else {
             selectedName = allNames[Math.floor(Math.random() * allNames.length)];
             selectedProdi = allProdis[Math.floor(Math.random() * allProdis.length)];
          }

          setFomoData({
            name: selectedName,
            prodi: selectedProdi,
            time: times[Math.floor(Math.random() * times.length)]
          });
          setIsVisible(true);
          
          setTimeout(() => {
            setIsVisible(false);
          }, 5000); 
        }, 15000); 

        const initialTimeout = setTimeout(() => {
          const initialName = db.length > 0 ? db[db.length - 1].nama : baseNames[0];
          const initialProdi = db.length > 0 ? db[db.length - 1].programStudi : baseProdis[0];
          setFomoData({
            name: initialName,
            prodi: initialProdi,
            time: "Baru saja"
          });
          setIsVisible(true);
          setTimeout(() => setIsVisible(false), 5000);
        }, 3000);

        return () => {
          clearInterval(intervalId);
          clearTimeout(initialTimeout);
        };
      }, [db]); 

      return (
        <div className={`fixed bottom-6 left-6 z-40 bg-white border-l-4 border-yellow-400 p-4 rounded-xl shadow-2xl flex items-center gap-4 max-w-sm transition-all duration-700 transform ${isVisible ? 'translate-y-0 opacity-100' : 'translate-y-10 opacity-0 pointer-events-none'}`}>
          <div className="bg-red-100 p-2.5 rounded-full text-red-700">
            <i className="fa-solid fa-bell text-2xl animate-pulse"></i>
          </div>
          <div>
            <p className="text-xs text-slate-500 mb-0.5 font-medium">{fomoData.time}</p>
            <p className="text-sm text-slate-800 leading-tight">
              <span className="font-bold">{fomoData.name}</span> telah mendaftar di prodi <br/>
              <span className="text-red-700 font-semibold">{fomoData.prodi}</span>
            </p>
          </div>
        </div>
      );
    }

    // Initialize React App
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>

<body class="bg-slate-50 text-slate-800 font-sans">
  
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useRef } = React;

    // ==============================================================================
    // KONFIGURASI BIAYA PRODI (Bisa diedit angkanya menyesuaikan yang ada di brosur)
    // ==============================================================================
    const BIAYA_PRODI = {
      "S1 Ilmu Kesehatan Masyarakat": "Rp 3.500.000",
      "D3 Kebidanan": "Rp 4.000.000",
      "D3 Keperawatan": "Rp 4.000.000",
      "S1 Ilmu Hukum": "Rp 2.000.000",
      "S1 Manajemen": "Rp 2.000.000",
      "S1 Psikologi": "Rp 2.000.000",
      "S1 PGSD": "Rp 2.000.000",
      "S1 Rekayasa Industri": "Rp 2.000.000",
      "S1 Teknik Informatika": "Rp 2.000.000"
    };

    // Main Application Component
    function App() {
      const [currentView, setCurrentView] = useState('landing');
      const [isPdfReady, setIsPdfReady] = useState(false);
      const [db, setDb] = useState([]);
      const [currentUser, setCurrentUser] = useState(null); 
      const [loggedInStudent, setLoggedInStudent] = useState(null); 
      const [toast, setToast] = useState({ visible: false, message: '', type: 'info' });
      const [isAdminLoggedIn, setIsAdminLoggedIn] = useState(false);

      const showToast = (message, type = 'info') => {
        setToast({ visible: true, message, type });
        setTimeout(() => setToast({ visible: false, message: '', type: 'info' }), 3000);
      };

      // Load Database from LocalStorage on mount
      useEffect(() => {
        const savedData = localStorage.getItem('pmb_database');
        if (savedData) {
          setDb(JSON.parse(savedData));
        }
        
        if (window.html2pdf) {
            setIsPdfReady(true);
        } else {
            setTimeout(() => setIsPdfReady(true), 1500); 
        }
      }, []);

      const saveToDb = (formData) => {
        const newUser = { ...formData, id: Date.now(), tanggalDaftar: new Date().toLocaleDateString('id-ID'), statusPembayaran: 'Belum Bayar' };
        const newDb = [...db, newUser];
        setDb(newDb);
        localStorage.setItem('pmb_database', JSON.stringify(newDb));
        setCurrentUser(newUser);
        setLoggedInStudent(newUser); 
        setCurrentView('success');
        showToast('Data Pendaftaran Berhasil Disimpan!', 'success');
        window.scrollTo(0, 0);
      };

      const handleStudentLogin = (user) => {
        setLoggedInStudent(user);
        setCurrentView('student-dashboard');
        showToast('Berhasil Login Calon Mahasiswa!', 'success');
        window.scrollTo(0, 0);
      };

      // Fungsi konfirmasi pembayaran oleh Admin
      const handleConfirmPayment = (userId) => {
        if(window.confirm('Anda yakin ingin mengonfirmasi pembayaran untuk pendaftar ini?')) {
           const updatedDb = db.map(user => 
             user.id === userId ? { ...user, statusPembayaran: 'Dikonfirmasi', tanggalDikonfirmasi: new Date().toLocaleDateString('id-ID') } : user
           );
           setDb(updatedDb);
           localStorage.setItem('pmb_database', JSON.stringify(updatedDb));
           showToast('Pembayaran berhasil dikonfirmasi!', 'success');
        }
      };

      // Fungsi hapus data maba oleh Admin
      const handleDeleteUser = (userId) => {
        if(window.confirm('PERINGATAN! Anda yakin ingin menghapus data calon mahasiswa ini secara permanen?')) {
          const updatedDb = db.filter(user => user.id !== userId);
          setDb(updatedDb);
          localStorage.setItem('pmb_database', JSON.stringify(updatedDb));
          showToast('Data calon mahasiswa berhasil dihapus.', 'success');
        }
      };

      // Fungsi update data maba oleh Admin (Edit)
      const handleUpdateUser = (updatedUserData) => {
        const updatedDb = db.map(user => 
          user.id === updatedUserData.id ? updatedUserData : user
        );
        setDb(updatedDb);
        localStorage.setItem('pmb_database', JSON.stringify(updatedDb));
        showToast('Data calon mahasiswa berhasil diperbarui!', 'success');
      };

      return (
        <div className="min-h-screen flex flex-col relative overflow-hidden">
          {/* Toast Notification */}
          <div className={`fixed top-20 right-4 z-50 transition-all duration-300 transform ${toast.visible ? 'translate-y-0 opacity-100' : '-translate-y-4 opacity-0 pointer-events-none'}`}>
            <div className={`flex items-center gap-3 px-4 py-3 rounded-lg shadow-xl text-white border ${toast.type === 'success' ? 'bg-green-600 border-green-700' : toast.type === 'error' ? 'bg-red-600 border-red-700' : 'bg-blue-600 border-blue-700'}`}>
              {toast.type === 'success' ? <i className="fa-solid fa-circle-check text-xl"></i> : <i className="fa-solid fa-circle-info text-xl"></i>}
              <span className="font-medium text-sm md:text-base">{toast.message}</span>
              <button onClick={() => setToast({ ...toast, visible: false })} className="ml-2 text-white/80 hover:text-white transition">
                <i className="fa-solid fa-xmark text-lg"></i>
              </button>
            </div>
          </div>

          {/* FOMO Notification */}
          <FomoNotification db={db} />

          {/* Navigation Bar */}
          <nav className="bg-red-700 text-white shadow-md sticky top-0 z-10 border-b-4 border-yellow-400">
            <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <div className="flex justify-between h-16 items-center overflow-x-auto no-scrollbar">
                <div 
                  className="flex items-center gap-2 cursor-pointer flex-shrink-0 mr-4" 
                  onClick={() => {setCurrentView('landing'); window.scrollTo(0,0);}}
                >
                  <i className="fa-solid fa-graduation-cap text-yellow-400 text-3xl"></i>
                  <span className="font-bold text-lg md:text-xl tracking-tight">PMB USINDO</span>
                </div>
                <div className="flex gap-1 md:gap-2 flex-shrink-0">
                  <button 
                    onClick={() => {setCurrentView('landing'); window.scrollTo(0,0);}}
                    className={`flex items-center gap-1 px-3 py-2 rounded-md transition-colors text-sm md:text-base ${currentView === 'landing' ? 'bg-red-900' : 'hover:bg-red-800'}`}
                  >
                    <i className="fa-solid fa-house"></i> <span className="hidden lg:inline">Beranda</span>
                  </button>
                  <button 
                    onClick={() => {setCurrentView('form'); window.scrollTo(0,0);}}
                    className={`flex items-center gap-1 px-3 py-2 rounded-md transition-colors text-sm md:text-base ${currentView === 'form' ? 'bg-red-900' : 'hover:bg-red-800'}`}
                  >
                    <i className="fa-solid fa-user-plus"></i> <span className="hidden lg:inline">Daftar</span>
                  </button>
                  
                  {/* Menu Login/Dashboard Mahasiswa */}
                  <button 
                    onClick={() => {setCurrentView(loggedInStudent ? 'student-dashboard' : 'student-login'); window.scrollTo(0,0);}}
                    className={`flex items-center gap-1 px-3 py-2 rounded-md transition-colors text-sm md:text-base ${(currentView === 'student-login' || currentView === 'student-dashboard') ? 'bg-yellow-500 text-red-900 font-bold' : 'bg-yellow-400 hover:bg-yellow-500 text-red-900 font-bold'}`}
                  >
                    <i className="fa-solid fa-user-graduate"></i> <span className="hidden sm:inline">{loggedInStudent ? 'Dashboard Maba' : 'Login Maba'}</span>
                  </button>

                  <button 
                    onClick={() => {setCurrentView('admin'); window.scrollTo(0,0);}}
                    className={`flex items-center gap-1 px-3 py-2 rounded-md transition-colors text-sm md:text-base ${currentView === 'admin' ? 'bg-red-900' : 'hover:bg-red-800'}`}
                  >
                    <i className="fa-solid fa-database"></i> <span className="hidden lg:inline">Admin</span>
                  </button>
                </div>
              </div>
            </div>
          </nav>

          {/* Main Content Area */}
          <main className="flex-grow flex flex-col">
            {currentView === 'landing' && <LandingPage setView={setCurrentView} />}
            {currentView === 'form' && <RegistrationForm submitForm={saveToDb} />}
            {currentView === 'success' && <SuccessPage user={currentUser} isPdfReady={isPdfReady} showToast={showToast} setView={setCurrentView} />}
            
            {/* Student Login & Dashboard Route */}
            {currentView === 'student-login' && <StudentLogin db={db} onLogin={handleStudentLogin} showToast={showToast} />}
            {currentView === 'student-dashboard' && <StudentDashboard student={db.find(u => u.id === loggedInStudent?.id) || loggedInStudent} BIAYA_PRODI={BIAYA_PRODI} isPdfReady={isPdfReady} showToast={showToast} onLogout={() => { setLoggedInStudent(null); setCurrentView('landing'); showToast('Berhasil Keluar', 'info'); }} />}

            {/* Admin Route */}
            {currentView === 'admin' && (
              !isAdminLoggedIn ? (
                 <AdminLogin onLogin={() => setIsAdminLoggedIn(true)} showToast={showToast} />
              ) : (
                 <AdminDashboard 
                    db={db} 
                    isPdfReady={isPdfReady} 
                    showToast={showToast} 
                    onLogout={() => setIsAdminLoggedIn(false)} 
                    onConfirmPayment={handleConfirmPayment} 
                    onDeleteUser={handleDeleteUser}
                    onUpdateUser={handleUpdateUser}
                    BIAYA_PRODI={BIAYA_PRODI} 
                 />
              )
            )}
          </main>

          {/* Footer */}
          <footer className="bg-slate-900 text-slate-300 py-10 border-t-4 border-yellow-400">
            <div className="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">
              <div>
                <h3 className="text-yellow-400 font-bold text-lg mb-4">Informasi & Pendaftaran</h3>
                <p className="flex items-center gap-2 mb-2"><i className="fa-solid fa-phone text-red-400 w-4"></i> Hubungi WhatsApp: <span className="font-bold text-white text-base">081929009212</span></p>
                <p className="flex items-center gap-2 mb-2"><i className="fa-solid fa-globe text-red-400 w-4"></i> www.usindo.ac.id</p>
                <p className="flex items-center gap-2 mb-2"><i className="fa-brands fa-instagram text-red-400 w-4 text-base"></i> @usindo.id</p>
                <p className="flex items-center gap-2"><i className="fa-brands fa-facebook text-red-400 w-4 text-base"></i> Universitas Sehati Indonesia</p>
              </div>
              <div>
                <h3 className="text-yellow-400 font-bold text-lg mb-4">Lokasi Kampus</h3>
                <div className="mb-4">
                  <p className="font-bold text-white flex items-center gap-2"><i className="fa-solid fa-location-dot text-red-400 w-4"></i> Kampus 1 USINDO</p>
                  <p className="text-slate-400 pl-6 leading-tight mt-1">Jl. Raya Kosambi - Telagasari Dusun Kawali,<br/>Pancawati, Kec. Klari, Karawang</p>
                </div>
                <div>
                  <p className="font-bold text-white flex items-center gap-2"><i className="fa-solid fa-location-dot text-red-400 w-4"></i> Kampus 2 USINDO</p>
                  <p className="text-slate-400 pl-6 leading-tight mt-1">Jl Raya Pangkal Perjuangan By Pass Karawang<br/>(200 Meter Dari SMKN 1 Karawang)</p>
                </div>
              </div>
              <div className="text-center md:text-right flex flex-col justify-center items-center md:items-end">
                <p className="mb-2">© 2026 Universitas Sehati Indonesia.</p>
                <div className="inline-block mt-2 p-4 border border-slate-700 rounded-lg bg-slate-800 text-center">
                  <p className="text-sm text-slate-400">Mengetahui,</p>
                  <p className="font-bold text-white text-lg mt-1">Hardi Hanto</p>
                  <p className="text-sm text-yellow-400">Panitia PMB</p>
                </div>
              </div>
            </div>
          </footer>
        </div>
      );
    }

    // --- STUDENT COMPONENTS ---
    function StudentLogin({ db, onLogin, showToast }) {
      const [nik, setNik] = useState('');
      const [tanggalLahir, setTanggalLahir] = useState('');
      
      // Captcha State
      const [captcha, setCaptcha] = useState({ n1: Math.floor(Math.random()*10)+1, n2: Math.floor(Math.random()*10)+1 });
      const [captchaInput, setCaptchaInput] = useState('');

      const handleSubmit = (e) => {
        e.preventDefault();

        // Validasi Captcha
        if (parseInt(captchaInput) !== (captcha.n1 + captcha.n2)) {
          showToast('Verifikasi keamanan salah! Anda terdeteksi sebagai bot.', 'error');
          // Regenerate captcha
          setCaptcha({ n1: Math.floor(Math.random()*10)+1, n2: Math.floor(Math.random()*10)+1 });
          setCaptchaInput('');
          return;
        }

        const foundStudent = db.find(user => user.nik === nik && user.tanggalLahir === tanggalLahir);
        
        if (foundStudent) {
          onLogin(foundStudent);
        } else {
          showToast('Data tidak ditemukan. Pastikan NIK dan Tanggal Lahir sesuai saat pendaftaran!', 'error');
          // Reset captcha for security
          setCaptcha({ n1: Math.floor(Math.random()*10)+1, n2: Math.floor(Math.random()*10)+1 });
          setCaptchaInput('');
        }
      };

      return (
        <div className="flex-grow flex items-center justify-center p-6 bg-slate-100">
          <div className="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md border-t-8 border-yellow-400">
            <div className="flex flex-col items-center mb-8 text-center">
              <div className="bg-yellow-100 p-4 rounded-full mb-4">
                <i className="fa-solid fa-user-graduate text-yellow-600 text-4xl"></i>
              </div>
              <h2 className="text-2xl font-bold text-slate-800">Login Calon Mahasiswa</h2>
              <p className="text-slate-500 text-sm mt-2">Masuk untuk melihat instruksi pembayaran formulir pendaftaran.</p>
            </div>

            <form onSubmit={handleSubmit} className="space-y-5">
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-1">NIK (Sesuai KTP/KK)</label>
                <input 
                  required 
                  type="number" 
                  value={nik} 
                  onChange={(e) => setNik(e.target.value)} 
                  className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-yellow-500 outline-none" 
                  placeholder="Masukkan 16 Digit NIK" 
                />
              </div>
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-1">Tanggal Lahir</label>
                <input 
                  required 
                  type="date" 
                  value={tanggalLahir} 
                  onChange={(e) => setTanggalLahir(e.target.value)} 
                  className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-yellow-500 outline-none" 
                />
              </div>
              
              {/* CAPTCHA SECTION */}
              <div className="bg-slate-50 p-4 rounded-lg border border-slate-200">
                <label className="block text-sm font-semibold text-slate-700 mb-2 flex items-center gap-2">
                  <i className="fa-solid fa-shield-halved text-green-600"></i> Verifikasi Keamanan
                </label>
                <div className="flex items-center gap-3">
                  <div className="bg-white px-4 py-2 border border-slate-300 rounded-lg font-bold text-slate-800 tracking-wider shadow-sm select-none">
                    {captcha.n1} + {captcha.n2} = ?
                  </div>
                  <input 
                    required 
                    type="number" 
                    value={captchaInput} 
                    onChange={(e) => setCaptchaInput(e.target.value)} 
                    className="flex-grow p-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-yellow-500 outline-none" 
                    placeholder="Hasil" 
                  />
                </div>
              </div>

              <button 
                type="submit" 
                className="w-full bg-yellow-400 hover:bg-yellow-500 text-red-900 font-bold py-3 px-4 rounded-lg shadow-md transition duration-200 text-lg mt-2"
              >
                Masuk Dashboard
              </button>
            </form>
          </div>
        </div>
      );
    }

    function StudentDashboard({ student, onLogout, BIAYA_PRODI, isPdfReady, showToast }) {
      const [isGeneratingForm, setIsGeneratingForm] = useState(false);
      const [isGeneratingInvoice, setIsGeneratingInvoice] = useState(false);

      if (!student) return null;

      const isConfirmed = student.statusPembayaran === 'Dikonfirmasi';
      const biayaTertagih = BIAYA_PRODI[student.programStudi] || "Rp -";

      // Penggunaan URL API Resmi WhatsApp untuk kestabilan di Maba
      const waNumber = "6281929009212";
      const waMessage = `Halo Panitia PMB USINDO. Saya ingin mengonfirmasi pembayaran biaya pendaftaran untuk Program Studi ${student.programStudi}.\n\nBerikut format lampiran bukti transfer saya:\n${student.nama}_[ISI TANGGAL TRANSFER]_[ISI NOMINAL]\n\nMohon untuk divalidasi. Terima kasih.`;
      const waLink = `https://api.whatsapp.com/send?phone=${waNumber}&text=${encodeURIComponent(waMessage)}`;

      const copyRekening = () => {
        navigator.clipboard.writeText("1754519044").then(() => {
          alert("Nomor rekening berhasil disalin!");
        });
      };

      // Fungsi Unduh Ulang Formulir
      const downloadFormulir = () => {
        if (!isPdfReady || !window.html2pdf) {
          alert("Sistem PDF masih memuat, silakan coba beberapa saat lagi.");
          return;
        }
        setIsGeneratingForm(true);
        showToast('Sedang memproses unduhan Formulir...', 'info');
        const element = document.getElementById('pdf-formulir-template-dashboard');

        const opt = {
          margin:       [2, 2, 2, 2],
          filename:     `Formulir_PMB_${student.nama.replace(/\s+/g, '_')}.pdf`,
          image:        { type: 'jpeg', quality: 0.98 },
          html2canvas:  { scale: 2, useCORS: true, logging: false, scrollY: 0, scrollX: 0 },
          jsPDF:        { unit: 'cm', format: 'a4', orientation: 'portrait' }
        };

        window.html2pdf().set(opt).from(element).save().then(() => {
          setIsGeneratingForm(false);
          showToast('Formulir PDF berhasil diunduh!', 'success');
        });
      };

      // Fungsi Unduh Invoice Pembayaran
      const downloadInvoice = () => {
        if (!isPdfReady || !window.html2pdf) {
          alert("Sistem PDF masih memuat, silakan coba beberapa saat lagi.");
          return;
        }
        setIsGeneratingInvoice(true);
        showToast('Sedang memproses unduhan Invoice...', 'info');
        const element = document.getElementById('pdf-invoice-template');

        const opt = {
          margin:       [2, 2, 2, 2],
          filename:     `Invoice_PMB_${student.nama.replace(/\s+/g, '_')}.pdf`,
          image:        { type: 'jpeg', quality: 0.98 },
          html2canvas:  { scale: 2, useCORS: true, logging: false, scrollY: 0, scrollX: 0 },
          jsPDF:        { unit: 'cm', format: 'a4', orientation: 'portrait' }
        };

        window.html2pdf().set(opt).from(element).save().then(() => {
          setIsGeneratingInvoice(false);
          showToast('Invoice PDF berhasil diunduh!', 'success');
        });
      };

      return (
        <div className="max-w-4xl mx-auto w-full p-4 sm:p-6 lg:p-8 my-4 relative">
          <div className="flex justify-between items-center mb-6">
             <h2 className="text-2xl font-bold text-red-800">Dashboard Calon Mahasiswa</h2>
             <button onClick={onLogout} className="text-slate-500 hover:text-red-600 font-semibold flex items-center gap-2 transition">
               <i className="fa-solid fa-right-from-bracket"></i> Keluar
             </button>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            {/* Profil Singkat */}

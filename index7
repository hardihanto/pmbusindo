    function SuccessPage({ user, isPdfReady, showToast, setView }) {
      const [isGenerating, setIsGenerating] = useState(false);

      const downloadPDF = () => {
        if (!isPdfReady || !window.html2pdf) {
          alert("Sistem PDF masih memuat, silakan coba beberapa saat lagi.");
          return;
        }
        
        setIsGenerating(true);
        showToast('Sedang memproses unduhan PDF...', 'info');
        const element = document.getElementById('pdf-formulir-template');

        const opt = {
          margin:       [2, 2, 2, 2],
          filename:     `Formulir_PMB_${user.nama.replace(/\s+/g, '_')}.pdf`,
          image:        { type: 'jpeg', quality: 0.98 },
          html2canvas:  { scale: 2, useCORS: true, logging: false, scrollY: 0, scrollX: 0 },
          jsPDF:        { unit: 'cm', format: 'a4', orientation: 'portrait' }
        };

        window.html2pdf().set(opt).from(element).save().then(() => {
          setIsGenerating(false);
          showToast('Formulir PDF berhasil diunduh!', 'success');
        });
      };

      if (!user) return <div className="p-10 text-center">Data tidak ditemukan.</div>;

      return (
        <div className="flex-grow flex flex-col items-center justify-center p-6 my-8">
          <div className="max-w-xl w-full bg-white p-8 rounded-2xl shadow-xl text-center">
            <i className="fa-solid fa-circle-check text-green-500 text-7xl mx-auto mb-6 block"></i>
            <h2 className="text-3xl font-bold text-slate-800 mb-2">Pendaftaran Berhasil!</h2>
            <p className="text-slate-600 mb-8">
              Terima kasih, <strong>{user.nama}</strong>. Data pendaftaran Anda telah tersimpan. Silakan unduh PDF dan lihat cara pembayaran.
            </p>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
              <button 
                onClick={downloadPDF}
                disabled={!isPdfReady || isGenerating}
                className={`w-full flex items-center justify-center gap-2 py-4 px-4 rounded-lg font-bold text-white transition shadow-lg ${!isPdfReady || isGenerating ? 'bg-slate-400 cursor-not-allowed' : 'bg-red-600 hover:bg-red-700'}`}

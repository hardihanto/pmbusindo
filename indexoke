              <div className="mt-2 inline-block bg-green-100 text-green-800 px-3 py-1 rounded font-bold text-sm border border-green-200">Terakreditasi BAIK</div>
            </div>

            <div className="pt-4">
              <button onClick={() => {setView('form'); window.scrollTo(0,0);}} className="bg-red-600 hover:bg-red-700 text-white font-bold py-4 px-10 rounded-full shadow-xl transform transition hover:-translate-y-1 hover:shadow-2xl flex items-center justify-center gap-3 mx-auto text-xl border-b-4 border-red-800">

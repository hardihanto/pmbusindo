                         <span className="text-xs text-slate-600 font-medium mt-1 inline-block bg-slate-100 p-1.5 rounded border border-slate-200">Program Studi: {student.programStudi}</span>
                       </td>
                       <td className="border border-slate-400 p-5 text-right font-bold text-xl align-top">{biayaTertagih}</td>
                     </tr>
                     <tr className="bg-slate-100 border-t-4 border-slate-500">
                       <td className="border border-slate-400 p-3 text-right font-black text-slate-900 text-lg">TOTAL DIBAYARKAN</td>
                       <td className="border border-slate-400 p-3 text-right text-2xl font-black text-green-700">{biayaTertagih}</td>
                     </tr>
                   </tbody>
                </table>

                <div className="flex justify-between items-end mt-8 text-sm">
                  <div className="w-1/2 text-slate-600 italic">
                    * Invoice ini sah dan dicetak otomatis secara elektronik.<br/>
                    * Simpan invoice ini sebagai bukti sah pembayaran Anda.
                  </div>
                  <div className="text-center w-1/3">
                    <p>Karawang, {student.tanggalDikonfirmasi || new Date().toLocaleDateString('id-ID')}</p>
                    <p className="mb-16 mt-1 font-semibold">Bagian Administrasi Keuangan</p>
                    <p className="font-bold underline text-base">Panitia PMB USINDO</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
        </div>
      );
    }

    function AdminLogin({ onLogin, showToast }) {
      const [username, setUsername] = useState('');
      const [password, setPassword] = useState('');
      const [captcha, setCaptcha] = useState({ n1: Math.floor(Math.random()*10)+1, n2: Math.floor(Math.random()*10)+1 });
      const [captchaInput, setCaptchaInput] = useState('');

      const handleSubmit = (e) => {
        e.preventDefault();
        if (parseInt(captchaInput) !== (captcha.n1 + captcha.n2)) {
          showToast('Verifikasi keamanan salah!', 'error');
          setCaptcha({ n1: Math.floor(Math.random()*10)+1, n2: Math.floor(Math.random()*10)+1 });
          setCaptchaInput('');
          return;
        }

        if (username === 'Admin!' && password === '@PMB#Usindo#1!') {
          onLogin();
          showToast('Login berhasil.', 'success');
        } else {
          showToast('Username atau password salah!', 'error');
          setCaptcha({ n1: Math.floor(Math.random()*10)+1, n2: Math.floor(Math.random()*10)+1 });
          setCaptchaInput('');
        }
      };

      return (
        <div className="flex-grow flex items-center justify-center p-6 bg-slate-100">
          <div className="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md border-t-8 border-red-700">
            <div className="flex flex-col items-center mb-8">
              <div className="bg-red-100 p-4 rounded-full mb-4">
                <i className="fa-solid fa-lock text-red-700 text-4xl"></i>
              </div>
              <h2 className="text-2xl font-bold text-slate-800">Login Administrator</h2>
            </div>
            <form onSubmit={handleSubmit} className="space-y-5">
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-1">Username</label>
                <input required type="text" value={username} onChange={(e) => setUsername(e.target.value)} className="w-full p-3 border border-slate-300 rounded-lg outline-none focus:ring-2 focus:ring-red-500" />
              </div>
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-1">Password</label>
                <input required type="password" value={password} onChange={(e) => setPassword(e.target.value)} className="w-full p-3 border border-slate-300 rounded-lg outline-none focus:ring-2 focus:ring-red-500" />
              </div>
              <div className="bg-slate-50 p-4 rounded-lg border border-slate-200">
                <label className="block text-sm font-semibold text-slate-700 mb-2">Verifikasi Keamanan</label>
                <div className="flex items-center gap-3">
                  <div className="bg-white px-4 py-2 border rounded-lg font-bold shadow-sm">{captcha.n1} + {captcha.n2} = ?</div>
                  <input required type="number" value={captchaInput} onChange={(e) => setCaptchaInput(e.target.value)} className="flex-grow p-2.5 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" />
                </div>
              </div>
              <button type="submit" className="w-full bg-red-700 hover:bg-red-800 text-white font-bold py-3 px-4 rounded-lg shadow-md mt-2">Masuk</button>
            </form>
          </div>
        </div>
      );
    }

    function AdminDashboard({ db, isPdfReady, showToast, onLogout, onConfirmPayment, onDeleteUser, onUpdateUser, BIAYA_PRODI, useCloud }) {
      const [isExporting, setIsExporting] = useState(false);
      const [editingUser, setEditingUser] = useState(null);

      const exportDatabasePDF = () => {
        if (!isPdfReady) { alert("Sistem PDF masih memuat, silakan coba beberapa saat lagi."); return; }
        setIsExporting(true);
        showToast('Mengekspor Laporan A4 Lanskap...', 'info');
        
        exportPDFHelper('pdf-database-template', `Database_PMB_${new Date().getTime()}.pdf`, true)
          .then(() => {
             setIsExporting(false);
             showToast('Database berhasil diekspor!', 'success');
          })
          .catch(() => {
             setIsExporting(false);
             showToast('Gagal mengekspor PDF!', 'error');
          });
      };

      const handleFollowUpWA = (user) => {
        let phone = user.noHp.replace(/\D/g, ''); 
        if (phone.startsWith('0')) phone = '62' + phone.substring(1);
        else if (phone.startsWith('8')) phone = '62' + phone;

        const biaya = BIAYA_PRODI[user.programStudi] || "Rp -";
        const message = `Halo Kak *${user.nama}*, perkenalkan kami dari Panitia PMB Universitas Sehati Indonesia (USINDO).\n\nKami melihat Anda telah mendaftar di program studi *${user.programStudi}* namun belum menyelesaikan tahap pembayaran awal pendaftaran sebesar *${biaya}*.\n\nSilakan transfer ke:\n🏦 *BNI: 17-545-190-44*\n👤 a.n *YAYASAN SEHATI INDONESIA MAJU*\n\nJika sudah, mohon balas dengan format:\n${user.nama}_[Tanggal]_[Nominal]\nSerta lampirkan foto struk transfernya. Terima kasih! 🙏`;

        window.open(`https://api.whatsapp.com/send?phone=${phone}&text=${encodeURIComponent(message)}`, '_blank', 'noopener,noreferrer');
      };

      const handleSaveEdit = (e) => {
        e.preventDefault();
        onUpdateUser(editingUser);
        setEditingUser(null);
      };

      return (
        <div className="max-w-[90rem] mx-auto w-full p-4 sm:p-6 lg:p-8 my-8">
          {!useCloud && (
            <div className="bg-red-100 border-l-4 border-red-600 text-red-800 p-4 mb-6 rounded shadow-sm">
              <h4 className="font-bold text-lg mb-1"><i className="fa-solid fa-triangle-exclamation"></i> MODE OFFLINE AKTIF (Data Tidak Tersimpan ke Cloud)</h4>
              <p className="text-sm mb-2">Aplikasi saat ini hanya berjalan menggunakan memori lokal perangkat Anda karena akses Firebase diblokir. Penyebab yang sering terjadi:</p>
              <ul className="list-disc ml-5 text-sm">
                  <li><strong>Domain belum diizinkan:</strong> Tambahkan domain tempat website ini berjalan (misalnya sandbox environment) ke tab <strong>Authentication -> Settings -> Authorized Domains</strong> di Firebase Console Anda.</li>
                  <li><strong>Izin API Key:</strong> Pada Google Cloud Console Anda, pastikan <em>Identity Toolkit API</em> sudah diizinkan untuk API Key tersebut.</li>
              </ul>
            </div>
          )}
          {/* Modal Edit Data */}
          {editingUser && (
            <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black bg-opacity-60 overflow-y-auto">
              <div className="bg-white rounded-xl shadow-2xl w-full max-w-4xl max-h-screen overflow-y-auto relative">
                <div className="sticky top-0 bg-white px-6 py-4 border-b flex justify-between items-center z-10">
                  <h3 className="text-xl font-bold text-slate-800">Edit Data Pendaftar</h3>
                  <button onClick={() => setEditingUser(null)} className="text-slate-400 hover:text-red-500 transition text-2xl leading-none">&times;</button>
                </div>
                <form onSubmit={handleSaveEdit} className="p-6">
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                     <div><label className="block text-xs font-medium text-slate-600 mb-1">Nama Lengkap</label><input required type="text" value={editingUser.nama} onChange={(e) => setEditingUser({...editingUser, nama: e.target.value})} className="w-full p-2 border rounded focus:ring-2 outline-none text-sm" /></div>
                     <div><label className="block text-xs font-medium text-slate-600 mb-1">NIK</label><input required type="number" value={editingUser.nik} onChange={(e) => setEditingUser({...editingUser, nik: e.target.value})} className="w-full p-2 border rounded focus:ring-2 outline-none text-sm" /></div>
                     <div><label className="block text-xs font-medium text-slate-600 mb-1">NISN</label><input required type="number" value={editingUser.nisn} onChange={(e) => setEditingUser({...editingUser, nisn: e.target.value})} className="w-full p-2 border rounded focus:ring-2 outline-none text-sm" /></div>
                     <div><label className="block text-xs font-medium text-slate-600 mb-1">No HP</label><input required type="tel" value={editingUser.noHp} onChange={(e) => setEditingUser({...editingUser, noHp: e.target.value})} className="w-full p-2 border rounded focus:ring-2 outline-none text-sm" /></div>
                     <div>
                       <label className="block text-xs font-medium text-slate-600 mb-1">Pilihan Program Studi</label>
                       <select value={editingUser.programStudi} onChange={(e) => setEditingUser({...editingUser, programStudi: e.target.value})} className="w-full p-2 border rounded focus:ring-2 outline-none text-sm bg-white">
                          <optgroup label="Fakultas Ilmu Kesehatan"><option value="S1 Ilmu Kesehatan Masyarakat">S1 Ilmu Kesehatan Masyarakat</option><option value="D3 Kebidanan">D3 Kebidanan</option><option value="D3 Keperawatan">D3 Keperawatan</option></optgroup>
                          <optgroup label="Fakultas Hukum & Ilmu Sosial"><option value="S1 Ilmu Hukum">S1 Ilmu Hukum</option><option value="S1 Manajemen">S1 Manajemen</option><option value="S1 Psikologi">S1 Psikologi</option><option value="S1 PGSD">S1 PGSD</option></optgroup>
                          <optgroup label="Fakultas Teknik"><option value="S1 Rekayasa Industri">S1 Rekayasa Industri</option><option value="S1 Teknik Informatika">S1 Teknik Informatika</option></optgroup>
                       </select>
                     </div>
                  </div>
                  <div className="mt-6 pt-4 border-t flex justify-end gap-3 sticky bottom-0 bg-white">
                     <button type="button" onClick={() => setEditingUser(null)} className="px-4 py-2 bg-slate-200 text-slate-700 rounded shadow text-sm font-bold">Batal</button>
                     <button type="submit" className="px-4 py-2 bg-blue-600 text-white rounded shadow text-sm font-bold">Simpan</button>
                  </div>
                </form>
              </div>
            </div>
          )}

          <div className="bg-white rounded-2xl shadow-lg border border-slate-100 overflow-hidden">
            <div className="p-6 border-b border-slate-200 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-slate-50">
              <div>
                <h2 className="text-2xl font-bold text-slate-800 flex items-center gap-2">
                  <i className="fa-solid fa-users text-blue-600 text-xl"></i> Database Pendaftar {useCloud ? '(Cloud)' : '(Local)'}
                </h2>
                <p className="text-slate-500 text-sm mt-1">Total Pendaftar: {db.length} Mahasiswa</p>
              </div>
              <div className="flex gap-2 w-full sm:w-auto">
                <button onClick={exportDatabasePDF} disabled={!isPdfReady || db.length === 0 || isExporting} className={`flex-1 sm:flex-none flex items-center justify-center gap-2 px-4 py-2 rounded-lg font-semibold transition ${db.length === 0 ? 'bg-slate-200 text-slate-400' : 'bg-green-600 hover:bg-green-700 text-white shadow'}`}>
                  {isExporting ? <><i className="fa-solid fa-spinner fa-spin text-lg"></i> Mengekspor...</> : <><i className="fa-solid fa-download text-lg"></i> Export PDF</>}
                </button>
                <button onClick={() => {onLogout(); showToast('Berhasil logout dari Admin.', 'info');}} className="flex-1 sm:flex-none flex items-center justify-center gap-2 px-4 py-2 rounded-lg font-semibold bg-slate-200 hover:bg-slate-300 text-slate-700 transition">
                  <i className="fa-solid fa-right-from-bracket text-lg"></i> Keluar
                </button>
              </div>
            </div>

            <div className="overflow-x-auto p-4">
              <table className="w-full text-sm text-left text-slate-600">
                <thead className="text-xs text-slate-700 uppercase bg-slate-100">
                  <tr>
                    <th className="px-3 py-3">No. Reg</th>
                    <th className="px-3 py-3">Nama</th>
                    <th className="px-3 py-3">Program Studi</th>
                    <th className="px-3 py-3">No. HP</th>
                    <th className="px-3 py-3">Tgl Daftar</th>
                    <th className="px-3 py-3 text-center">Status</th>
                    <th className="px-3 py-3 text-center">Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  {db.length > 0 ? (
                    db.map((user) => {
                      const isConfirmed = user.statusPembayaran === 'Dikonfirmasi';
                      return (
                        <tr key={user.id} className="border-b hover:bg-slate-50">
                          <td className="px-3 py-3 font-mono text-xs font-semibold">PMB-{user.id.toString().slice(-6)}</td>
                          <td className="px-3 py-3 font-medium text-slate-900">{user.nama}</td>
                          <td className="px-3 py-3">{user.programStudi}</td>
                          <td className="px-3 py-3">{user.noHp}</td>
                          <td className="px-3 py-3">{user.tanggalDaftar}</td>
                          <td className="px-3 py-3 text-center">
                            <span className={`px-2 py-1 rounded text-xs font-bold border ${isConfirmed ? 'bg-green-100 text-green-700 border-green-200' : 'bg-yellow-100 text-yellow-700 border-yellow-200'}`}>
                              {isConfirmed ? 'Lunas' : (user.statusPembayaran || 'Belum Bayar')}
                            </span>
                          </td>
                          <td className="px-3 py-3">
                             <div className="flex flex-wrap items-center justify-center gap-1.5">
                               {!isConfirmed && (
                                 <>
                                   <button onClick={() => handleFollowUpWA(user)} className="bg-green-500 hover:bg-green-600 text-white text-[10px] px-2 py-1.5 rounded" title="Follow Up WA"><i className="fa-brands fa-whatsapp"></i> WA</button>
                                   <button onClick={() => onConfirmPayment(user.id)} className="bg-blue-600 hover:bg-blue-700 text-white text-[10px] px-2 py-1.5 rounded" title="Konfirmasi Lunas"><i className="fa-solid fa-check"></i> Lunas</button>
                                 </>
                               )}
                               <button onClick={() => setEditingUser(user)} className="bg-orange-500 hover:bg-orange-600 text-white text-[10px] px-2 py-1.5 rounded"><i className="fa-solid fa-pen"></i> Edit</button>
                               <button onClick={() => onDeleteUser(user.id)} className="bg-red-600 hover:bg-red-700 text-white text-[10px] px-2 py-1.5 rounded"><i className="fa-solid fa-trash"></i></button>
                             </div>
                          </td>
                        </tr>
                      );
                    })
                  ) : (
                    <tr><td colSpan="7" className="px-4 py-8 text-center text-slate-500">Belum ada data pendaftar di server.</td></tr>
                  )}
                </tbody>
              </table>
            </div>
          </div>

          {/* TEMPLATE PDF MURNI */}
          <div style={{ display: 'none' }}>
            
            {/* Laporan Admin Lanskap (Lebar A4 Lanskap 1123px) */}
            <div id="pdf-database-template" style={{ width: '1050px', backgroundColor: 'white', padding: '40px', color: 'black', boxSizing: 'border-box', margin: 'auto' }} className="font-sans text-left">
              <div className="text-center mb-8">
                <h1 className="text-2xl font-bold uppercase text-red-800">Laporan Database Pendaftaran Mahasiswa Baru</h1>
                <p className="text-lg font-bold">UNIVERSITAS SEHATI INDONESIA (USINDO)</p>
                <p className="text-md">Tahun Akademik 2026/2027</p>
                <p className="text-sm mt-2">Diekspor pada: {new Date().toLocaleString('id-ID')}</p>
              </div>

              <table className="w-full text-sm text-left border-collapse border border-slate-400">
                <thead>
                  <tr className="bg-slate-200">
                    <th className="border border-slate-400 p-3 text-center w-10">No</th>
                    <th className="border border-slate-400 p-3">No. Registrasi</th>
                    <th className="border border-slate-400 p-3">Nama Lengkap</th>
                    <th className="border border-slate-400 p-3">NISN / NIK</th>
                    <th className="border border-slate-400 p-3">Program Studi</th>
                    <th className="border border-slate-400 p-3">Status</th>
                    <th className="border border-slate-400 p-3">No. HP</th>
                    <th className="border border-slate-400 p-3">Tgl Daftar</th>
                  </tr>
                </thead>
                <tbody>
                  {db.map((user, index) => (
                    <tr key={user.id} style={{ pageBreakInside: 'avoid' }} className="nth-child(even):bg-slate-50">
                      <td className="border border-slate-400 p-3 text-center text-slate-800">{index + 1}</td>
                      <td className="border border-slate-400 p-3 font-mono text-slate-800">PMB-{user.id}</td>
                      <td className="border border-slate-400 p-3 uppercase text-slate-800 font-bold">{user.nama}</td>
                      <td className="border border-slate-400 p-3 text-slate-800">{user.nisn}<br/><span className="text-xs text-slate-500">{user.nik}</span></td>
                      <td className="border border-slate-400 p-3 text-slate-800">{user.programStudi}</td>
                      <td className="border border-slate-400 p-3 text-slate-800 font-semibold">{user.statusPembayaran === 'Dikonfirmasi' ? 'Lunas' : (user.statusPembayaran || 'Belum Bayar')}</td>
                      <td className="border border-slate-400 p-3 text-slate-800">{user.noHp}</td>
                      <td className="border border-slate-400 p-3 text-slate-800">{user.tanggalDaftar}</td>
                    </tr>
                  ))}
                </tbody>
              </table>

              <div className="flex justify-end mt-12 pr-10" style={{ pageBreakInside: 'avoid' }}>
                <div className="text-center text-slate-900">
                  <p>Mengetahui,</p>
                  <p className="mb-24 mt-2">Panitia PMB</p>
                  <p className="font-bold underline text-lg">Hardi Hanto</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      );
    }

    function FomoNotification({ db }) {
      const [isVisible, setIsVisible] = useState(false);
      const [fomoData, setFomoData] = useState({ name: '', prodi: '', time: '' });

      useEffect(() => {
        const baseNames = ["Andi dari Jakarta", "Siti dari Karawang", "Budi dari Bekasi", "Ayu dari Purwakarta", "Dimas dari Subang"];
        const baseProdis = ["S1 Teknik Informatika", "S1 Ilmu Hukum", "S1 Manajemen", "D3 Keperawatan", "S1 Ilmu Kesehatan Masyarakat"];
        const intervalId = setInterval(() => {
          setIsVisible(true);
          setTimeout(() => setIsVisible(false), 5000); 
        }, 15000); 
        return () => clearInterval(intervalId);
      }, []); 

      return (
        <div className={`fixed bottom-6 left-6 z-40 bg-white border-l-4 border-yellow-400 p-4 rounded-xl shadow-2xl flex items-center gap-4 max-w-sm transition-all duration-700 transform ${isVisible ? 'translate-y-0 opacity-100' : 'translate-y-10 opacity-0 pointer-events-none'}`}>
          <div className="bg-red-100 p-2.5 rounded-full text-red-700">
            <i className="fa-solid fa-bell text-2xl animate-pulse"></i>
          </div>
          <div>
            <p className="text-xs text-slate-500 mb-0.5 font-medium">Baru saja</p>
            <p className="text-sm text-slate-800 leading-tight">Seseorang telah mendaftar di prodi <span className="text-red-700 font-semibold">USINDO</span></p>
          </div>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>

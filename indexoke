    const { useState, useEffect, useRef } = React;

    // ==============================================================================
    // KONFIGURASI DATABASE CLOUD FIREBASE
    // ==============================================================================
    const CUSTOM_FIREBASE_CONFIG = {
      apiKey: "AIzaSyBu-m0yJAHG8yWLD9N2_tTaZkANwm8d6lE",
      authDomain: "utopian-hearth-425509-e2.firebaseapp.com",
      projectId: "utopian-hearth-425509-e2",
      storageBucket: "utopian-hearth-425509-e2.firebasestorage.app",
      messagingSenderId: "226044792739",
      appId: "1:226044792739:web:5951f12e7ce43f844b9416",
      measurementId: "G-JHV5LVJNPJ"
    }; 

    // ==============================================================================
    // SISTEM HYBRID CLOUD & LOCAL DB
    // ==============================================================================
    let app, auth, dbFirestore, appId;
    let isFirebaseActive = false;

    try {
        const envConfig = typeof __firebase_config !== 'undefined' ? (typeof __firebase_config === 'string' ? JSON.parse(__firebase_config) : __firebase_config) : null;
        const finalConfig = CUSTOM_FIREBASE_CONFIG || envConfig;

        if (finalConfig) {
            app = initializeApp(finalConfig);
            auth = getAuth(app);
            dbFirestore = getFirestore(app);
            appId = CUSTOM_FIREBASE_CONFIG ? 'custom-app' : (typeof __app_id !== 'undefined' ? __app_id : 'default-app-id');
            isFirebaseActive = true;
            console.log("Status: Firebase siap diinisialisasi");
        }
    } catch(e) {
        console.warn("Koneksi Cloud gagal, beralih ke Mode Offline aman.", e);
    }

    // ==============================================================================
    // KONFIGURASI BIAYA PRODI
    // ==============================================================================
    const BIAYA_PRODI = {
      "S1 Ilmu Kesehatan Masyarakat": "Rp 3.500.000",
      "D3 Kebidanan": "Rp 4.000.000",
      "D3 Keperawatan": "Rp 4.000.000",
      "S1 Ilmu Hukum": "Rp 2.000.000",
      "S1 Manajemen": "Rp 2.000.000",
      "S1 Psikologi": "Rp 2.000.000",
      "S1 PGSD": "Rp 2.000.000",
      "S1 Rekayasa Industri": "Rp 2.000.000",
      "S1 Teknik Informatika": "Rp 2.000.000"
    };

    // ==============================================================================
    // FUNGSI PDF REVOLUSIONER
    // ==============================================================================
    const exportPDFHelper = (elementId, filename, isLandscape = false) => {
        return new Promise((resolve, reject) => {
            if (!window.html2pdf) {
                reject("Mesin PDF belum siap.");
                return;
            }
            
            const sourceElement = document.getElementById(elementId);
            if (!sourceElement) {
                reject("Template PDF tidak ditemukan.");
                return;
            }

            const clone = sourceElement.cloneNode(true);
            clone.style.display = 'block'; 
            
            const wrapper = document.createElement('div');
            wrapper.style.position = 'absolute';
            wrapper.style.left = '-15000px'; 
            wrapper.style.top = '0';
            wrapper.style.backgroundColor = '#ffffff'; 
            wrapper.style.padding = '0';

            wrapper.appendChild(clone);
            document.body.appendChild(wrapper);

            const opt = {
              margin:       10, 
              filename:     filename,
              image:        { type: 'jpeg', quality: 1 },
              html2canvas:  { scale: 2, useCORS: true, scrollY: 0 },
              jsPDF:        { unit: 'mm', format: 'a4', orientation: isLandscape ? 'landscape' : 'portrait' }
            };

            window.html2pdf().set(opt).from(clone).save().then(() => {
                document.body.removeChild(wrapper);
                resolve();
            }).catch(err => {
                if(document.body.contains(wrapper)) document.body.removeChild(wrapper);
                reject(err);
            });
        });
    };

    // ==============================================================================
    // MAIN APP COMPONENT
    // ==============================================================================
    function App() {
      const [currentView, setCurrentView] = useState('landing');
      const [isPdfReady, setIsPdfReady] = useState(false);
      
      const [db, setDb] = useState([]);
      const [userAuth, setUserAuth] = useState(null);
      const [useCloud, setUseCloud] = useState(isFirebaseActive); // Track active cloud state

      const [currentUser, setCurrentUser] = useState(null); 
      const [loggedInStudent, setLoggedInStudent] = useState(null); 
      const [toast, setToast] = useState({ visible: false, message: '', type: 'info' });
      const [isAdminLoggedIn, setIsAdminLoggedIn] = useState(false);

      const showToast = (message, type = 'info') => {
        setToast({ visible: true, message, type });
        setTimeout(() => setToast({ visible: false, message: '', type: 'info' }), 3000);
      };

      // 1. INIT AUTH & PDF MESIN DENGAN GRACEFUL FALLBACK
      useEffect(() => {
        if (window.html2pdf) {
            setIsPdfReady(true);
        } else {
            setTimeout(() => setIsPdfReady(true), 1500); 
        }

        if (!isFirebaseActive) {
            const savedData = localStorage.getItem('pmb_database');
            if (savedData) setDb(JSON.parse(savedData));
            return;
        }

        const initAuth = async () => {
          try {
            if (CUSTOM_FIREBASE_CONFIG) {
              await signInAnonymously(auth);
            } else if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
              await signInWithCustomToken(auth, __initial_auth_token);
            } else {
              await signInAnonymously(auth);
            }
            setUseCloud(true);
          } catch(e) { 
            console.error("Auth error detail:", e); 
            // PENANGANAN ERROR: Jika API Key dibatasi atau domain tidak diizinkan, aplikasi tidak boleh crash
            setUseCloud(false);
            const savedData = localStorage.getItem('pmb_database');
            if (savedData) setDb(JSON.parse(savedData));

            if (e.code === 'auth/admin-restricted-operation') {
                setTimeout(() => showToast('Firebase memblokir akses login. Beralih ke Mode Offline (Data disimpan lokal).', 'error'), 1000);
            } else {
                setTimeout(() => showToast('Gagal terhubung ke Cloud. Beralih ke Mode Offline.', 'error'), 1000);
            }
          }
        };
        
        initAuth();

        const unsubscribe = onAuthStateChanged(auth, (user) => {
            setUserAuth(user);
        });
        return () => unsubscribe && unsubscribe();
      }, []);

      // 2. FETCH DATA DARI CLOUD (REAL-TIME) - Dijalankan HANYA JIKA sudah terautentikasi
      useEffect(() => {
        if (!useCloud || !userAuth) return; // Mencegah operasi pembacaan sebelum auth sukses

        const usersRef = collection(dbFirestore, 'pmb_users');
        const unsubscribe = onSnapshot(usersRef, (snapshot) => {
           const usersData = snapshot.docs.map(doc => doc.data());
           setDb(usersData.sort((a,b) => b.id - a.id));
        }, (error) => {
           console.error("Firestore Error:", error);
           showToast('Gagal membaca database. Izin Firestore mungkin ditolak.', 'error');
        });

        return () => unsubscribe && unsubscribe();
      }, [useCloud, userAuth]); // Bergantung pada status cloud dan otentikasi user

      // 3. FUNGSI MENYIMPAN DATA (Mendukung Cloud & Offline)
      const saveToDb = async (formData) => {
        const newId = Date.now();
        const newUser = { ...formData, id: newId, tanggalDaftar: new Date().toLocaleDateString('id-ID'), statusPembayaran: 'Belum Bayar' };
        
        if (useCloud && userAuth) {
            try {
              const docRef = doc(dbFirestore, 'pmb_users', newId.toString());
              await setDoc(docRef, newUser);
              showToast('Data Berhasil Disimpan ke Cloud Realtime!', 'success');
            } catch(err) {
              alert("GAGAL MENYIMPAN DATA!\n\nPesan Error: " + err.message);
              return; 
            }
        } else {
            const newDb = [newUser, ...db];
            setDb(newDb);
            localStorage.setItem('pmb_database', JSON.stringify(newDb));
            showToast('Tersimpan di Memori Lokal', 'info');
        }

        setCurrentUser(newUser);
        setLoggedInStudent(newUser); 
        setCurrentView('success');
        window.scrollTo(0, 0);
      };

      const handleStudentLogin = (user) => {
        setLoggedInStudent(user);
        setCurrentView('student-dashboard');
        showToast('Berhasil Login Calon Mahasiswa!', 'success');
        window.scrollTo(0, 0);
      };

      const handleConfirmPayment = async (userId) => {
        if(window.confirm('Anda yakin ingin mengonfirmasi pembayaran pendaftar ini?')) {
           const updatedInfo = { statusPembayaran: 'Dikonfirmasi', tanggalDikonfirmasi: new Date().toLocaleDateString('id-ID') };
           if (useCloud && userAuth) {
               try {
                 const docRef = doc(dbFirestore, 'pmb_users', userId.toString());
                 await updateDoc(docRef, updatedInfo);
                 showToast('Pembayaran berhasil dikonfirmasi!', 'success');
               } catch(err) { showToast('Gagal mengubah data cloud.', 'error'); }
           } else {
               const newDb = db.map(u => u.id === userId ? { ...u, ...updatedInfo } : u);
               setDb(newDb);
               localStorage.setItem('pmb_database', JSON.stringify(newDb));
               showToast('Pembayaran berhasil dikonfirmasi!', 'success');
           }
        }
      };

      const handleDeleteUser = async (userId) => {
        if(window.confirm('PERINGATAN! Anda yakin ingin menghapus data calon mahasiswa ini secara permanen?')) {
          if (useCloud && userAuth) {
              try {
                const docRef = doc(dbFirestore, 'pmb_users', userId.toString());
                await deleteDoc(docRef);
                showToast('Data berhasil dihapus dari sistem.', 'success');
              } catch(err) { showToast('Gagal menghapus data cloud.', 'error'); }
          } else {
              const newDb = db.filter(u => u.id !== userId);
              setDb(newDb);
              localStorage.setItem('pmb_database', JSON.stringify(newDb));
              showToast('Data berhasil dihapus.', 'success');
          }
        }
      };

      const handleUpdateUser = async (updatedUserData) => {
        if (useCloud && userAuth) {
            try {
               const docRef = doc(dbFirestore, 'pmb_users', updatedUserData.id.toString());
               await updateDoc(docRef, updatedUserData);
               showToast('Data calon mahasiswa berhasil diperbarui!', 'success');
            } catch(err) { showToast('Gagal memperbarui data.', 'error'); }
        } else {
            const newDb = db.map(u => u.id === updatedUserData.id ? updatedUserData : u);
            setDb(newDb);
            localStorage.setItem('pmb_database', JSON.stringify(newDb));
            showToast('Data berhasil diperbarui!', 'success');
        }
      };

      return (
        <div className="min-h-screen flex flex-col relative overflow-x-hidden bg-slate-50">
          {/* Toast Notification Terjaga */}
          <div className={`fixed top-20 right-4 z-50 transition-all duration-300 transform ${toast.visible ? 'translate-y-0 opacity-100' : '-translate-y-4 opacity-0 pointer-events-none'}`}>
            <div className={`flex items-center gap-3 px-4 py-3 rounded-lg shadow-xl text-white border ${toast.type === 'success' ? 'bg-green-600 border-green-700' : toast.type === 'error' ? 'bg-red-600 border-red-700' : 'bg-blue-600 border-blue-700'}`}>
